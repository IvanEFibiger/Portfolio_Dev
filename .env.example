# ============================================
# Portfolio Iván Fibiger — Variables de entorno
# ============================================
# Copiar este archivo como .env y completar los valores

# General
NODE_ENV=development
PORT=3000

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=55432
DB_USERNAME=portfolio
DB_PASSWORD=portfolio_dev_password
DB_DATABASE=portfolio_ivan

# Puerto del contenedor PostgreSQL publicado al host por Docker Compose
POSTGRES_HOST_PORT=55432

# Puertos publicados por Docker Compose
API_HOST_PORT=3000
WEB_HOST_PORT=4200

# Frontend SSR (servidor Node de Angular)
# Hosts permitidos por el motor SSR. Sin esto el render cae a CSR.
# En produccion usar el dominio real, ej: ivanfibiger.dev
NG_ALLOWED_HOSTS=localhost

# JWT
JWT_SECRET=cambiar-este-secreto-en-produccion
JWT_EXPIRATION=1h

# CORS
CORS_ORIGIN=http://localhost:4200

# Frontend
FRONTEND_URL=http://localhost:4200
SITE_URL=https://ivanfibigerdev.com

# API
API_URL=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=10

# Swagger (solo desarrollo)
SWAGGER_ENABLED=true

# Cache
CACHE_DRIVER=memory
CACHE_TTL=60000
# CACHE_REDIS_URL=redis://localhost:6379
